generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Only needed against a pooled connection (e.g. Supabase's pgBouncer pooler on
  // port 6543), which doesn't support the advisory locks `prisma migrate` needs.
  // Falls back to DATABASE_URL when DIRECT_URL isn't set, so this is a no-op for
  // a plain, unpooled Postgres instance (local dev, most other hosts).
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  BUYER
  VENDOR
  ADMIN
  // Separate from ADMIN: the only role that can see/manage the platform
  // wallet and the company/developer/super-admin revenue-split settings.
  // Regular ADMIN retains every other admin capability (vendor approval,
  // store settings, slides, vendor withdrawal approve/reject) but has no
  // visibility into those two — enforced both by RolesGuard on the API
  // (@Roles(UserRole.SUPER_ADMIN) only, vs. the shared ADMIN+SUPER_ADMIN
  // list everywhere else) and by hiding the mobile screens client-side.
  SUPER_ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum VendorVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  FAILED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  FAILED
  FULFILLING
  COMPLETED
  CANCELLED
}

enum VendorOrderStatus {
  PENDING
  ACCEPTED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentProvider {
  FLUTTERWAVE
  OPAY
}

enum PaymentStatus {
  INITIATED
  SUCCESSFUL
  FAILED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  REJECTED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole @default(BUYER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendorProfile VendorProfile?
  cart          Cart?
  addresses     Address[]
  orders        Order[]

  @@map("users")
}

model VendorProfile {
  id                 String                    @id @default(uuid())
  userId             String                    @unique
  businessName       String
  description        String?
  logoUrl            String?
  status             VendorStatus              @default(PENDING)
  commissionRate     Decimal                   @default(10.0) @db.Decimal(5, 2)
  payoutAccount      Json?
  verificationStatus VendorVerificationStatus  @default(NOT_STARTED)
  verificationJobId  String?
  verifiedAt         DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  products           Product[]
  vendorOrders       VendorOrder[]
  wallet             Wallet?
  withdrawalRequests WithdrawalRequest[]

  @@map("vendor_profiles")
}

model Category {
  id       String     @id @default(uuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryToCategory")
  products Product[]

  @@map("categories")
}

model Product {
  id          String        @id @default(uuid())
  vendorId    String
  categoryId  String
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("NGN")
  stock       Int           @default(0)
  images      String[]
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor     VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category   Category      @relation(fields: [categoryId], references: [id])
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Cart {
  id     String @id @default(uuid())
  userId String @unique

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id         String  @id @default(uuid())
  cartId     String
  productId  String
  quantity   Int
  priceAtAdd Decimal @db.Decimal(12, 2)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  label     String
  line1     String
  line2     String?
  city      String
  state     String
  country   String   @default("Nigeria")
  phone     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

model Order {
  id                String          @id @default(uuid())
  buyerId           String
  addressId         String
  totalAmount       Decimal         @db.Decimal(12, 2)
  currency          String          @default("NGN")
  status            OrderStatus     @default(PENDING_PAYMENT)
  paymentProvider   PaymentProvider?
  paymentReference  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  buyer        User          @relation(fields: [buyerId], references: [id])
  address      Address       @relation(fields: [addressId], references: [id])
  vendorOrders VendorOrder[]
  payments     Payment[]

  @@index([buyerId])
  @@map("orders")
}

model VendorOrder {
  id                  String            @id @default(uuid())
  orderId             String
  vendorId            String
  subtotal            Decimal           @db.Decimal(12, 2)
  commissionAmount    Decimal           @db.Decimal(12, 2)
  vendorPayoutAmount  Decimal           @db.Decimal(12, 2)
  // Subdivide commissionAmount (company + developer = commissionAmount) and a
  // flat extra cut of subtotal for the super-admin wallet — all frozen at
  // checkout time from PlatformPaymentSettings, same as the two fields above.
  companyAmount       Decimal           @default(0) @db.Decimal(12, 2)
  developerAmount     Decimal           @default(0) @db.Decimal(12, 2)
  superAdminAmount    Decimal           @default(0) @db.Decimal(12, 2)
  status              VendorOrderStatus @default(PENDING)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  vendor             VendorProfile       @relation(fields: [vendorId], references: [id])
  items              OrderItem[]
  walletTransactions WalletTransaction[]

  @@index([orderId])
  @@index([vendorId])
  @@map("vendor_orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  vendorOrderId String
  productId     String
  title         String
  price         Decimal @db.Decimal(12, 2)
  quantity      Int

  vendorOrder VendorOrder @relation(fields: [vendorOrderId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Payment {
  id                 String          @id @default(uuid())
  orderId            String
  provider           PaymentProvider
  providerReference  String          @unique
  amount             Decimal         @db.Decimal(12, 2)
  currency           String          @default("NGN")
  status             PaymentStatus   @default(INITIATED)
  rawWebhookPayload  Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

model AppSettings {
  id             String   @id @default(uuid())
  primaryColor   String   @default("#111827")
  secondaryColor String   @default("#4B5563")
  accentColor    String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt

  @@map("app_settings")
}

model Slide {
  id        String   @id @default(uuid())
  imageUrl  String
  title     String?
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("slides")
}

// Singleton (application-enforced, same convention as AppSettings): governs
// how each sale's commission is subdivided (company/developer, must sum to
// 100) and the flat extra cut of subtotal routed to the super-admin wallet.
// Only ever readable/writable by SUPER_ADMIN — see UserRole.SUPER_ADMIN.
model PlatformPaymentSettings {
  id                    String   @id @default(uuid())
  companySharePercent   Decimal  @default(70.0) @db.Decimal(5, 2)
  developerSharePercent Decimal  @default(30.0) @db.Decimal(5, 2)
  superAdminFeePercent  Decimal  @default(0.10) @db.Decimal(5, 2)
  payoutAccount         Json?
  updatedAt             DateTime @updatedAt

  @@map("platform_payment_settings")
}

// One row per vendor (vendorId set) plus exactly one platform/super-admin
// row (vendorId null, application-enforced singleton) — see Wallet.vendorId.
model Wallet {
  id        String   @id @default(uuid())
  vendorId  String?  @unique
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  currency  String   @default("NGN")
  updatedAt DateTime @updatedAt

  vendor       VendorProfile?      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  withdrawals  WithdrawalRequest[]

  @@map("wallets")
}

model WalletTransaction {
  id                  String                @id @default(uuid())
  walletId            String
  type                WalletTransactionType
  amount              Decimal               @db.Decimal(12, 2)
  balanceAfter        Decimal               @db.Decimal(12, 2)
  description         String
  vendorOrderId       String?
  withdrawalRequestId String?
  createdAt           DateTime              @default(now())

  wallet            Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)
  vendorOrder       VendorOrder?       @relation(fields: [vendorOrderId], references: [id])
  withdrawalRequest WithdrawalRequest? @relation(fields: [withdrawalRequestId], references: [id])

  @@index([walletId])
  @@map("wallet_transactions")
}

model WithdrawalRequest {
  id                String           @id @default(uuid())
  walletId          String
  // null for the platform wallet's self-initiated withdrawals (no separate
  // vendor to attribute it to — the requesting super admin is reviewedBy).
  vendorId          String?
  amount            Decimal          @db.Decimal(12, 2)
  status            WithdrawalStatus @default(PENDING)
  providerReference String?
  failureReason     String?
  requestedAt       DateTime         @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  paidAt            DateTime?

  wallet       Wallet              @relation(fields: [walletId], references: [id])
  vendor       VendorProfile?      @relation(fields: [vendorId], references: [id])
  transactions WalletTransaction[]

  @@index([walletId])
  @@index([vendorId])
  @@map("withdrawal_requests")
}
