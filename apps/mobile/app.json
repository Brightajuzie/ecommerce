{
  "expo": {
    "name": "IkStore",
    "slug": "ikstore",
    "scheme": "ikstore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "IkStore uses Face ID to let you unlock the app instead of retyping your password."
      }
    },
    "android": {
      "package": "com.ikstore.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow IkStore to use Face ID to unlock the app."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "IkStore uses your photo library to upload product photos, logos, and banner images."
        }
      ],
      "expo-secure-store"
    ]
  }
}
