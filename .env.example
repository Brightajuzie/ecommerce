# --- Database ---
DATABASE_URL="postgresql://ikstore:ikstore@localhost:5432/ikstore?schema=public"

# --- App ---
APP_URL="http://localhost:3000"
PORT=3000
NODE_ENV=development

# --- Production hardening (see README "Deploying to production") ---
CORS_ORIGIN=""
TRUST_PROXY=false
SWAGGER_ENABLED=true

# --- Auth ---
JWT_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Flutterwave (sandbox keys from dashboard.flutterwave.com) ---
FLW_PUBLIC_KEY=""
FLW_SECRET_KEY=""
FLW_ENCRYPTION_KEY=""
FLW_WEBHOOK_HASH="change-me-webhook-secret-hash"

# --- Opay (sandbox keys from merchant.opaycheckout.com) ---
OPAY_MERCHANT_ID=""
OPAY_PUBLIC_KEY=""
OPAY_SECRET_KEY=""

# --- Cloudinary (image uploads + enhancement, from cloudinary.com console) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Smile ID (vendor biometric KYC, from portal.usesmileid.com) ---
SMILE_ID_PARTNER_ID=""
SMILE_ID_API_KEY=""
SMILE_ID_ENVIRONMENT="sandbox"
